   "source": [
    "sample_news = \"\"\"\n",
    "The government announced a new policy regarding education reforms.\n",
    "\"\"\"\n",
    "\n",
    "# Preprocess\n",
    "cleaned = preprocess_text(sample_news)\n",
    "\n",
    "# Vectorize\n",
    "vectorized = vectorizer.transform([cleaned])\n",
    "\n",
    "# Predict\n",
    "prediction = model.predict(vectorized)\n",
    "\n",
    "if prediction[0] == 0:\n",
    "    print(\"Fake News\")\n",
    "else:\n",
    "    print(\"Real News\")"
   ]
