   "source": [
    "# Add labels\n",
    "fake[\"label\"] = 0\n",
    "true[\"label\"] = 1\n",
    "\n",
    "# Combine datasets\n",
    "df = pd.concat([fake, true], axis=0)\n",
    "\n",
    "# Shuffle dataset\n",
    "df = df.sample(frac=1)\n",
    "\n",
    "# Reset index\n",
    "df.reset_index(inplace=True)\n",
    "\n",
    "# Display combined dataset\n",
    "print(df.head())\n",
    "\n",
    "# Dataset info\n",
    "print(df.info())"
   ]
